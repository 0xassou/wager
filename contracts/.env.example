# ============================================================
# Copie ce fichier vers .env  :   cp .env.example .env
# Puis remplis les valeurs. NE COMMITE JAMAIS le fichier .env !
# ============================================================

# Clé privée du wallet qui déploie (exporte-la depuis MetaMask :
# Détails du compte > Exporter la clé privée). Il lui faut du USDC
# de test sur Arc pour payer le gas — sur Arc, le gas se paie en
# USDC (la devise native), pas en ETH.
PRIVATE_KEY=

# RPC Arc Testnet (vérifié : chain ID 5042002)
ARC_RPC_URL=https://rpc.testnet.arc.network

# Optionnel mais recommandé : RPC dédié Alchemy, utilisé en priorité sur
# ARC_RPC_URL ci-dessus si renseigné. Le RPC public a un rate limit très
# strict (~1 req/s, erreur "request limit reached").
# Créer une clé gratuite : https://www.alchemy.com/rpc/arc-testnet
# → Create new app → chaîne "Arc" → réseau "Testnet" → copier l'URL
# (format https://arc-testnet.g.alchemy.com/v2/<api-key>)
ARC_RPC_URL_ALCHEMY=

# Adresse du USDC officiel de Circle sur Arc Testnet.
# Vérifiée sur https://developers.circle.com/stablecoins/usdc-contract-addresses
# Si tu laisses vide, le script de déploiement créera un MockUSDC de test.
USDC_ADDRESS=0x3600000000000000000000000000000000000000
