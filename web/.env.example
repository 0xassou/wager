# ============================================================
# Copie ce fichier vers .env.local :   cp .env.example .env.local
# Ces variables sont PUBLIQUES (préfixe NEXT_PUBLIC_) — aucune
# clé privée ici, jamais.
# ============================================================

# Adresses obtenues après `npm run deploy:arc` dans /contracts
NEXT_PUBLIC_MARKET_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# RPC Arc Testnet (vérifié : chain ID 5042002)
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network

# Optionnel mais recommandé : RPC dédié Alchemy, utilisé en priorité sur
# NEXT_PUBLIC_ARC_RPC_URL ci-dessus si renseigné. Le RPC public a un rate
# limit très strict (~1 req/s, erreur "request limit reached").
# Créer une clé gratuite : https://www.alchemy.com/rpc/arc-testnet
# → Create new app → chaîne "Arc" → réseau "Testnet" → copier l'URL
# (format https://arc-testnet.g.alchemy.com/v2/<api-key>)
NEXT_PUBLIC_ARC_RPC_URL_ALCHEMY=

# Optionnel : ID de projet WalletConnect (https://cloud.walletconnect.com)
# pour la connexion mobile. Les extensions (MetaMask...) marchent sans.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
